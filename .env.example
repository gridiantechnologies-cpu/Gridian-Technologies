# ──────────────────────────────────────────────────────────────────────────────
# Gridian Technologies — Environment Variables
# Copy this file to .env.local (never commit .env.local to git)
# ──────────────────────────────────────────────────────────────────────────────

# ── IndexNow ──────────────────────────────────────────────────────────────────
# Used by /api/indexnow to ping Bing when you publish new content.
# Must match the filename in /public/<key>.txt
INDEXNOW_KEY=gt-indexnow-key-2024

# ── Site ──────────────────────────────────────────────────────────────────────
# Override this in Vercel environment variables with your real domain.
NEXT_PUBLIC_SITE_URL=https://gridian-technologies.vercel.app
